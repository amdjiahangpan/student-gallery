        self.env = {}
        self.files = {}
        self.single_result = None
        self.single_info = None
        self.multi_results = None
        self.tasks = []
        self.build_ui()
        self.run_async_task(self.check_env())

    def build_ui(self):
        clear_output(wait=True)
        style = {
            "panel": widgets.Layout(padding="15px", margin="10px 0", border="1px solid #e0e0e0", border_radius="8px"),
            "button": widgets.Layout(padding="10px", margin="5px 0", width="100%"),
            "title": widgets.Layout(margin="10px 0", padding="5px", background="#f5f7fa", border_radius="5px"),
            "output": widgets.Layout(padding="10px", margin="10px 0", border="1px solid #e0e0e0", border_radius="8px", min_height="400px"),
            "stop": widgets.Layout(padding="10px", margin="5px 0", width="100%", background_color="#e74c3c", color="white")
        }

        display(widgets.HTML("<h1>📝 Deep Text Analysis Tool (ROCm Accelerated)</h1>"))

        self.env_panel = widgets.HTML(
            value="🔍 Checking environment...",
            layout=style["panel"]
        )
        display(self.env_panel)

        single_title = widgets.HTML("<h3>📄 Single File Deep Analysis</h3>", layout=style["title"])
        self.upload_single = widgets.FileUpload(accept=".txt", multiple=False, description="Upload TXT", layout=style["button"])
        self.upload_single.observe(self.on_single_upload, names='value')
        self.info_panel = widgets.HTML(value="Upload a file to view info", layout=style["panel"])
        self.btn_run = widgets.Button(description="Analyze", button_style="primary", disabled=True, layout=style["button"])
        self.btn_stop = widgets.Button(description="Stop", button_style="danger", disabled=True, layout=style["stop"])
        self.btn_run.on_click(self.start_single)
        self.btn_stop.on_click(self.stop_single)
        self.out_single = widgets.VBox([
            widgets.HTML("<h4>Analysis Results</h4>"),
            widgets.HTML(value="Waiting...", layout=style["output"])
        ])
        self.save_md = widgets.Button(description="Save MD", layout=style["button"])
        self.save_json = widgets.Button(description="Save JSON", layout=style["button"])
        self.save_md.on_click(self.save_md_click)
        self.save_json.on_click(self.save_json_click)
        self.save_row = widgets.HBox([self.save_md, self.save_json])
        self.save_row.layout.display = 'none'

        single_box = widgets.VBox([
            single_title, self.upload_single, self.info_panel,
            widgets.HBox([self.btn_run, self.btn_stop]),
            self.out_single, self.save_row
        ], layout=style["panel"])
        display(single_box)

        multi_title = widgets.HTML("<h3>📊 Multi-File Comparison</h3>", layout=style["title"])
        self.upload_multi = widgets.FileUpload(accept=".txt", multiple=True, description="Upload multiple TXT", layout=style["button"])
        self.upload_multi.observe(self.on_multi_upload, names='value')
        self.list_panel = widgets.HTML(value="Upload files to view list", layout=style["panel"])
        self.btn_compare = widgets.Button(description="Compare", button_style="success", disabled=True, layout=style["button"])
        self.btn_stop_cmp = widgets.Button(description="Stop", button_style="danger", disabled=True, layout=style["stop"])
        self.btn_compare.on_click(self.start_multi)
        self.btn_stop_cmp.on_click(self.stop_multi)
        self.out_multi = widgets.VBox([
            widgets.HTML("<h4>Comparison Results</h4>"),
            widgets.HTML(value="Waiting...", layout=style["output"])
        ])
        self.save_cmp = widgets.Button(description="Save Report", layout=style["button"])
        self.save_cmp.on_click(self.save_cmp_click)
        self.save_cmp_row = widgets.HBox([self.save_cmp])
        self.save_cmp_row.layout.display = 'none'

        multi_box = widgets.VBox([
            multi_title, self.upload_multi, self.list_panel,
            widgets.HBox([self.btn_compare, self.btn_stop_cmp]),
            self.out_multi, self.save_cmp_row
        ], layout=style["panel"])
        display(multi_box)

    def run_async_task(self, coro):
        t = asyncio.create_task(coro)
        self.tasks.append(t)
        def cleanup(task):
            if task in self.tasks:
                self.tasks.remove(task)
        t.add_done_callback(cleanup)
        return t

    async def check_env(self):
        self.env = await EnvChecker.check_all()
        lines = ["<h4>🔧 Environment Status</h4><ul>"]
        ok = True
        for k, v in self.env.items():
            if "❌" in v:
                ok = False
            lines.append(f"<li>{k}: {v}</li>")
        lines.append("</ul>")
        if ok:
            lines.append("<p style='color:green'>✅ Ready</p>")
            self.btn_run.disabled = False
            self.btn_compare.disabled = False
        else:
            lines.append("<p style='color:orange'>⚠️ Some checks failed</p>")
        self.env_panel.value = "".join(lines)

    def on_single_upload(self, change):
        try:
            f = change['new']
            if not f:
                self.info_panel.value = "Upload a file"
                self.btn_run.disabled = True
                return
            name, data = list(f.items())[0] if isinstance(f, dict) else ("file.txt", f[0])
            _, info = FileParser.parse_uploaded_file(data, name)
            self.files[name] = info
            self.single_info = info
            html = "<h4>File Info</h4><ul>"
            for k, v in info.items():
                html += f"<li>{k}: {v}</li>"
            html += "</ul>"
            self.info_panel.value = html
            self.btn_run.disabled = False
        except Exception as e:
            self.info_panel.value = f"<p style='color:red'>❌ Error: {str(e)}</p>"
            self.btn_run.disabled = True

    def on_multi_upload(self, change):
        try:
            f = change['new']
            if not f:
                self.list_panel.value = "Upload files"
                self.btn_compare.disabled = True
                return
            items = list(f.items()) if isinstance(f, dict) else [(f"file{i+1}.txt", x) for i, x in enumerate(f)]
            html = "<h4>Files</h4><table border='1' cellpadding='8' width='100%'><tr><th>Name</th><th>Size</th><th>Tokens</th><th>Status</th></tr>"
            self.files = {}
            for name, data in items:
                try:
                    _, info = FileParser.parse_uploaded_file(data, name)
                    self.files[name] = info
                    html += f"<tr><td>{name}</td><td>{info['Size (bytes)']}</td><td>{info['Tokens']}</td><td>✅ OK</td></tr>"
                except:
                    html += f"<tr><td>{name}</td><td>-</td><td>-</td><td>❌ Fail</td></tr>"
            html += "</table>"
            self.list_panel.value = html
            self.btn_compare.disabled = len(self.files) < 2
        except Exception as e:
            self.list_panel.value = f"<p style='color:red'>❌ Error: {str(e)}</p>"
            self.btn_compare.disabled = True

    def start_single(self, _):
        self.btn_run.disabled = True
        self.btn_stop.disabled = False
        self.out_single.children[1].value = "<p>Analyzing...</p>"
        self.save_row.layout.display = 'none'
        self.task_single = self.run_async_task(self.do_single())

    async def do_single(self):
        try:
            f = self.upload_single.value
            name, data = list(f.items())[0] if isinstance(f, dict) else ("file.txt", f[0])
            text, info = FileParser.parse_uploaded_file(data, name)
            res = await TextAnalyzer.analyze(text)
            self.single_result = res
            self.single_info = info
            if "Error" in res:
                html = f"<h2>❌ Failed</h2><p>Error: {res['Error']}</p><p>Time: {res['Time']}</p>"
            else:
                html = f"""
<h2>Analysis Results: {name}</h2>
<h3>Basic</h3>
<table border='1' cellpadding='8' width='100%'>
<tr><td>Summary</td><td>{res['Summary']}</td></tr>
<tr><td>Theme</td><td>{res['Theme']}</td></tr>
<tr><td>Keywords</td><td>{res['Keywords']}</td></tr>
<tr><td>Sentiment</td><td>{res['Sentiment']}</td></tr>
<tr><td>Type</td><td>{res['Type']}</td></tr>
</table>
<h3>Deep</h3>
<table border='1' cellpadding='8' width='100%'>
<tr><td>Thesis</td><td>{res['Thesis']}</td></tr>
<tr><td>Evidence</td><td>{res['Evidence']}</td></tr>
<tr><td>Assumptions</td><td>{res['Assumptions']}</td></tr>
<tr><td>Use Cases</td><td>{res['Use Cases']}</td></tr>
<tr><td>Limitations</td><td>{res['Limitations']}</td></tr>
</table>
<p>Time: {res['Time']} | Chunks: {res['Chunks']} | Valid: {res['Valid Chunks']}</p>
"""
            self.out_single.children[1].value = html
            self.save_row.layout.display = 'flex'
        except Exception as e:
            self.out_single.children[1].value = f"<p style='color:red'>❌ Error: {str(e)}</p>"
        finally:
            self.btn_run.disabled = False
            self.btn_stop.disabled = True

    def stop_single(self, _):
        if hasattr(self, 'task_single') and not self.task_single.done():
            self.task_single.cancel()
            self.out_single.children[1].value = "<p>Stopped</p>"
        self.btn_run.disabled = False
        self.btn_stop.disabled = True

    def start_multi(self, _):
        self.btn_compare.disabled = True
        self.btn_stop_cmp.disabled = False
        self.out_multi.children[1].value = "<p>Comparing...</p>"
        self.save_cmp_row.layout.display = 'none'
        self.task_multi = self.run_async_task(self.do_multi())

    async def do_multi(self):
        try:
            f = self.upload_multi.value
            items = list(f.items()) if isinstance(f, dict) else [(f"f{i+1}.txt", x) for i, x in enumerate(f)]
            res = {}
            self.multi_results = res
            for name, data in items:
                try:
                    t, _ = FileParser.parse_uploaded_file(data, name)
                    res[name] = await TextAnalyzer.analyze(t)
                except:
                    res[name] = {"Error": "Failed", "Time": "0s"}
            cmp = await TextComparator.compare(res)
            self.out_multi.children[1].value = cmp.replace('\n', '<br>')
            self.save_cmp_row.layout.display = 'flex'
        except Exception as e:
            self.out_multi.children[1].value = f"<p style='color:red'>❌ Error: {str(e)}</p>"
        finally:
            self.btn_compare.disabled = False
            self.btn_stop_cmp.disabled = True

    def stop_multi(self, _):
        if hasattr(self, 'task_multi') and not self.task_multi.done():
            self.task_multi.cancel()
            self.out_multi.children[1].value = "<p>Stopped</p>"
        self.btn_compare.disabled = False
        self.btn_stop_cmp.disabled = True

    def save_md_click(self, _):
        msg = SaveTool.save_analysis_result(self.single_info["Filename"], self.single_result, self.single_info, "md")
        display(HTML(f"<div style='color:#27ae60'>{msg}</div>"))

    def save_json_click(self, _):
        msg = SaveTool.save_analysis_result(self.single_info["Filename"], self.single_result, self.single_info, "json")
        display(HTML(f"<div style='color:#27ae60'>{msg}</div>"))

    def save_cmp_click(self, _):
        self.run_async_task(self._save_cmp())

    async def _save_cmp(self):
        msg = await SaveTool.save_compare_result(self.multi_results, "md")
        display(HTML(f"<div style='color:#27ae60'>{msg}</div>"))

# ====================== Entry Point ======================
def start_text_analyzer():
    try:
        import tiktoken
        import aiohttp
        import ipywidgets
        import nest_asyncio
    except ImportError:
        os.system("pip install -q tiktoken aiohttp ipywidgets nest-asyncio")
        nest_asyncio.apply()
    TextAnalysisUI()

if __name__ == "__main__":
    start_text_analyzer()
