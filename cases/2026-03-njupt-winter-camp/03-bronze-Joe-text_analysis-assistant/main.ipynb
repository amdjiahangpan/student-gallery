# ====================== Core Configuration ======================
class Config:
    OLLAMA_API_URL      = "http://open-webui-ollama.open-webui:11434"
    OLLAMA_GENERATE_URL = f"{OLLAMA_API_URL}/api/generate"
    OLLAMA_TAGS_URL     = f"{OLLAMA_API_URL}/api/tags"
    DEFAULT_MODEL       = "qwen3-coder:30b"
    NUM_CTX             = 32768
    API_TIMEOUT         = 180
    PROMPT_RESERVE      = 1000
    MAX_RETRIES         = 2
    RETRY_DELAY         = 1.5
    RATE_LIMIT          = 6
    RATE_WINDOW         = 60
    TASK_TIMEOUT        = 300

    os.environ["HIP_VISIBLE_DEVICES"] = "0"
    os.environ["OLLAMA_HF_DEVICE_MAP"] = "auto"
    os.environ["PYTORCH_ROCM_ARCH"] = "gfx906"
    os.environ["OLLAMA_GPU"] = "1"

# ====================== Environment Checker ======================
class EnvChecker:
    @staticmethod
    async def check_all():
        results = {
            "ROCm Acceleration": EnvChecker.check_rocm(),
            "Ollama Service": await EnvChecker.check_ollama_service(),
            "Model Availability": await EnvChecker.check_model(),
            "Network Connectivity": await EnvChecker.check_network()
        }
        return results

    @staticmethod
    def check_rocm():
        try:
            if "HIP_VISIBLE_DEVICES" not in os.environ:
                return "❌ Disabled (environment variable not set)"
            
            try:
                result = subprocess.run(
                    ["rocminfo"],
                    capture_output=True,
                    text=True,
                    timeout=10
                )
            except (subprocess.TimeoutExpired, FileNotFoundError):
                return "⚠️ ROCm tools not installed (CPU fallback)"
            
            if result.returncode == 0 and result.stdout and "gfx" in result.stdout:
                return "✅ Enabled (GPU acceleration active)"
            else:
                return "⚠️ No ROCm device detected (using CPU)"
        except Exception as e:
            return f"❌ Check failed: {str(e)[:20]}"

    @staticmethod
    async def check_ollama_service():
        try:
            timeout = ClientTimeout(total=5)
            async with aiohttp.ClientSession(timeout=timeout) as session:
                resp = await session.get(Config.OLLAMA_API_URL)
                if resp.status == 200:
                    return "✅ Service online"
                else:
                    return f"❌ Status code: {resp.status}"
        except asyncio.TimeoutError:
            return "❌ Connection timeout"
        except Exception as e:
            return f"❌ Connection failed: {str(e)[:20]}"

    @staticmethod
    async def check_model():
        try:
            timeout = ClientTimeout(total=5)
            async with aiohttp.ClientSession(timeout=timeout) as session:
                resp = await session.get(Config.OLLAMA_TAGS_URL)
                if resp.status == 200:
                    data = await resp.json()
                    models = [m["name"] for m in data.get("models", [])]
                    if Config.DEFAULT_MODEL in models:
                        return "✅ Model downloaded"
                    else:
                        return f"❌ Model missing: ollama pull {Config.DEFAULT_MODEL}"
                else:
                    return f"❌ API error: {resp.status}"
        except asyncio.TimeoutError:
            return "❌ Model check timeout"
        except Exception as e:
            return f"❌ Check failed: {str(e)[:20]}"

    @staticmethod
    async def check_network():
        try:
            timeout = ClientTimeout(total=3)
            async with aiohttp.ClientSession(timeout=timeout) as session:
                await session.get(f"{Config.OLLAMA_API_URL}/api/tags")
                return "✅ Cluster network OK"
        except asyncio.TimeoutError:
            return "❌ Network timeout"
        except Exception as e:
            return f"❌ Network unreachable: {str(e)[:20]}"

# ====================== Async Retry & Timeout Decorator ======================
def async_retry_with_timeout(max_retries=Config.MAX_RETRIES, delay=Config.RETRY_DELAY, timeout=Config.TASK_TIMEOUT):
    def decorator(func):
        @wraps(func)
        async def wrapper(*args, **kwargs):
            async def task_with_timeout():
                for attempt in range(max_retries):
                    try:
                        return await func(*args, **kwargs)
                    except Exception as e:
                        if attempt == max_retries - 1:
                            raise Exception(f"Failed after {max_retries} retries: {str(e)}")
                        await asyncio.sleep(delay * (attempt + 1))
                return None

            try:
                return await asyncio.wait_for(task_with_timeout(), timeout=timeout)
            except asyncio.TimeoutError:
                raise Exception(f"Task timed out after {timeout}s")
        return wrapper
    return decorator

# ====================== Rate Limiter ======================
class RateLimiter:
    def __init__(self, max_requests=Config.RATE_LIMIT, time_window=Config.RATE_WINDOW):
        self.max_requests = max_requests
        self.time_window = time_window
        self.request_timestamps = deque()
        self.lock = asyncio.Lock()

    async def acquire(self):
        async with self.lock:
            now = time.time()
            while self.request_timestamps and now - self.request_timestamps[0] > self.time_window:
                self.request_timestamps.popleft()
            if len(self.request_timestamps) >= self.max_requests:
                wait_time = self.time_window - (now - self.request_timestamps[0])
                await asyncio.sleep(wait_time + 0.5)
            self.request_timestamps.append(now)

rate_limiter = RateLimiter()

# ====================== Token Utilities ======================
class Tokenizer:
    _encoder = None

    @staticmethod
    def get_encoder():
        if not Tokenizer._encoder:
            try:
                Tokenizer._encoder = tiktoken.encoding_for_model("qwen-32k")
            except:
                Tokenizer._encoder = tiktoken.get_encoding("cl100k_base")
        return Tokenizer._encoder

    @staticmethod
    def count(text):
        return len(Tokenizer.get_encoder().encode(text))

    @staticmethod
    def truncate(text, max_tokens):
        encoder = Tokenizer.get_encoder()
        tokens = encoder.encode(text)
        if len(tokens) <= max_tokens:
            return text
        truncated = encoder.decode(tokens[:max_tokens])
        end_chars = {'.', '。', '！', '？', ';', '；'}
        last_pos = max([truncated.rfind(c) for c in end_chars] + [max_tokens - 10])
        return truncated[:last_pos + 1].strip()

# ====================== Text Splitter ======================
class TextSplitter:
    @staticmethod
    def split(text, overlap_ratio=0.15):
        prompt_base = TextAnalyzer.build_prompt("")
        prompt_tokens = Tokenizer.count(prompt_base)
        max_chunk_tokens = 16384 - prompt_tokens - Config.PROMPT_RESERVE
        if max_chunk_tokens <= 0:
            max_chunk_tokens = 16384 - 2000

        text = re.sub(r'\n+', '\n', text).strip()
        paragraphs = [p.strip() for p in text.split('\n') if p.strip()]

        chunks = []
        current_chunk = ""
        current_tokens = 0
        overlap_tokens = int(max_chunk_tokens * overlap_ratio)

        for para in paragraphs:
            para_tokens = Tokenizer.count(para)

            if para_tokens > max_chunk_tokens:
                if current_chunk:
                    chunks.append(current_chunk)
                    overlap_text = TextSplitter._get_overlap_text(current_chunk, overlap_tokens)
                    current_chunk = overlap_text
                    current_tokens = Tokenizer.count(current_chunk)

                sentences = re.split(r'(?<=[。！？;.!?])\s*', para)
                for sent in sentences:
                    sent_tokens = Tokenizer.count(sent)
                    if sent_tokens > max_chunk_tokens:
                        if current_chunk:
                            chunks.append(current_chunk)
                            current_chunk = ""
                            current_tokens = 0
                        truncated = Tokenizer.truncate(sent, max_chunk_tokens)
                        chunks.append(truncated)
                        continue

                    if current_tokens + sent_tokens > max_chunk_tokens:
                        chunks.append(current_chunk)
                        overlap_text = TextSplitter._get_overlap_text(current_chunk, overlap_tokens)
                        current_chunk = overlap_text + sent
                        current_tokens = Tokenizer.count(current_chunk)
                    else:
                        current_chunk += (" " if current_chunk else "") + sent
                        current_tokens += sent_tokens

            else:
                if current_tokens + para_tokens > max_chunk_tokens:
                    chunks.append(current_chunk)
                    overlap_text = TextSplitter._get_overlap_text(current_chunk, overlap_tokens)
                    current_chunk = overlap_text + para
                    current_tokens = Tokenizer.count(current_chunk)
                else:
                    current_chunk += ("\n" if current_chunk else "") + para
                    current_tokens += para_tokens

        if current_chunk.strip():
            chunks.append(current_chunk.strip())

        chunks = [c.strip() for c in chunks if c.strip()]
        return chunks

    @staticmethod
    def _get_overlap_text(text, overlap_tokens):
        if overlap_tokens <= 0 or not text:
            return ""
        tokens = Tokenizer.get_encoder().encode(text)
        if len(tokens) <= overlap_tokens:
            return text
        overlap_token_list = tokens[-overlap_tokens:]
        overlap_text = Tokenizer.get_encoder().decode(overlap_token_list)
        end_chars = {'.', '。', '！', '？', ';', '；', '\n'}
        last_pos = max([overlap_text.rfind(c) for c in end_chars] + [-1])
        if last_pos >= 0:
            overlap_text = overlap_text[last_pos+1:].strip()
        return overlap_text

# ====================== Text Analyzer ======================
class TextAnalyzer:
    @staticmethod
    def build_prompt(text):
        system_role = """
<system>
You are an expert in multilingual text analysis. Follow a strict Chain-of-Thought process:
1. Identify document type
2. Extract core themes and key information
3. Analyze logic structure and arguments
4. Evaluate value, limitations, and assumptions
5. Output strictly in the required format

Output must be consistent with the input language.
</system>
"""

        few_shot_examples = """
<examples>
Example Input:
Artificial intelligence applications in healthcare are rapidly growing. LLM-based diagnostic systems improve efficiency by 30% and reduce misdiagnosis by 15%, but face challenges in privacy, bias, regulation, and cost.

Example Output:
Summary: AI in healthcare grows rapidly with 30% efficiency gain and 15% fewer misdiagnoses, yet faces privacy, bias, regulation, and high deployment costs.
Theme: AI, Healthcare, LLM
Keywords: AI, healthcare, LLM, diagnosis, efficiency, misdiagnosis, privacy, bias, regulation, cost
Sentiment: Neutral
Type: Industry Analysis
Thesis: AI healthcare is effective but faces challenges
Evidence: 30% efficiency, 15% fewer errors, privacy risks, bias, regulation, cost
Assumptions: AI can compensate for resource shortages; data can be used compliantly
Use Cases: Hospital diagnosis, data analytics, policy making
Limitations: Privacy risks, bias, high cost, unclear regulation
</examples>
"""

        output_format = """
Text to analyze:
{text}

Output Format (strict):
Summary: <content>
Theme: <content>
Keywords: <content>
Sentiment: <content>
Type: <content>
Thesis: <content>
Evidence: <content>
Assumptions: <content>
Use Cases: <content>
Limitations: <content>
"""
        full_prompt = f"{system_role}{few_shot_examples}{output_format.format(text=text)}"
        return full_prompt.strip()

    @staticmethod
    def parse_result(raw_output):
        result = {
            "Summary": "N/A",
            "Theme": "N/A",
            "Keywords": "N/A",
            "Sentiment": "N/A",
            "Type": "N/A",
            "Thesis": "N/A",
            "Evidence": "N/A",
            "Assumptions": "N/A",
            "Use Cases": "N/A",
            "Limitations": "N/A",
            "Time": "0s",
            "Chunks": 0,
            "Valid Chunks": 0
        }
        keys = list(result.keys())
        for key in keys:
            if key in ["Time", "Chunks", "Valid Chunks"]:
                continue
            pattern = re.compile(f"{key}\\s*[:]\\s*(.*?)(?=\\n|$)", re.DOTALL | re.IGNORECASE)
            match = pattern.search(raw_output)
            if match:
                result[key] = match.group(1).strip()
        return result

    @staticmethod
    @async_retry_with_timeout()
    async def call_ollama(prompt):
        await rate_limiter.acquire()
        timeout = ClientTimeout(total=Config.API_TIMEOUT)
        async with aiohttp.ClientSession(timeout=timeout) as session:
            response = await session.post(
                Config.OLLAMA_GENERATE_URL,
                json={
                    "model": Config.DEFAULT_MODEL,
                    "prompt": prompt,
                    "stream": False,
                    "num_ctx": Config.NUM_CTX,
                    "temperature": 0.1,
                    "top_p": 0.95,
                    "max_tokens": 4096
                }
            )
            if response.status != 200:
                raise Exception(f"API error {response.status}")
            data = await response.json()
            res = data.get("response", "").strip()
            if not res:
                raise Exception("Empty model response")
            return res

    @staticmethod
    async def analyze(text):
        start = time.time()
        chunks = TextSplitter.split(text)
        if not chunks:
            return {"Error": "No valid text", "Time": f"{time.time()-start:.2f}s"}

        chunk_results = []
        for i, chunk in enumerate(chunks):
            try:
                prompt = TextAnalyzer.build_prompt(chunk)
                raw = await TextAnalyzer.call_ollama(prompt)
                parsed = TextAnalyzer.parse_result(raw)
                if parsed["Summary"] == "N/A" or parsed["Thesis"] == "N/A":
                    continue
                chunk_results.append(parsed)
            except Exception as e:
                print(f"Chunk {i+1} failed: {str(e)[:50]}")
                continue

        if not chunk_results:
            return {"Error": "All chunks invalid", "Time": f"{time.time()-start:.2f}s"}

        summary_lines = []
        for idx, cr in enumerate(chunk_results, 1):
            summary_lines.append(f"""
[Chunk {idx}]
Summary: {cr['Summary']}
Theme: {cr['Theme']}
Thesis: {cr['Thesis']}
Evidence: {cr['Evidence']}
Assumptions: {cr['Assumptions']}
Use Cases: {cr['Use Cases']}
Limitations: {cr['Limitations']}
""")

        cascade_prompt = f"""
<system>
You are a text synthesis expert. Merge chunk analyses into a single coherent report.
Follow the same output format exactly.
</system>

Chunk Results:
{chr(10).join(summary_lines)}

Output Format:
Summary: <overall summary>
Theme: <overall theme>
Keywords: <keywords>
Sentiment: <overall sentiment>
Type: <document type>
Thesis: <overall thesis>
Evidence: <combined evidence>
Assumptions: <key assumptions>
Use Cases: <integrated use cases>
Limitations: <overall limitations>
"""

        try:
            cascade_raw = await TextAnalyzer.call_ollama(cascade_prompt)
            final = TextAnalyzer.parse_result(cascade_raw)
            final["Chunks"] = len(chunks)
            final["Valid Chunks"] = len(chunk_results)
            final["Time"] = f"{time.time()-start:.2f}s"
            return final
        except Exception as e:
            return {"Error": f"Merge failed: {str(e)[:30]}", "Time": f"{time.time()-start:.2f}s"}

# ====================== Multi-Text Comparator ======================
class TextComparator:
    @staticmethod
    async def compare(results):
        valid = {k: v for k, v in results.items() if "Error" not in v}
        n = len(valid)
        report = [
            "# 📊 Multi-Text Deep Comparative Analysis",
            "",
            f"> Files analyzed: {len(results)}, valid: {n}, failed: {len(results)-n}",
            "> Analysis covers similarities, differences, conflicts, complementarity, and recommendations."
        ]
        if n >= 2:
            files = sorted(valid.keys())
            summaries = []
            for i, fname in enumerate(files, 1):
                r = valid[fname]
                summaries.append(f"""
File {i}: {fname}
- Theme: {r['Theme']}
- Type: {r['Type']}
- Thesis: {r['Thesis']}
- Evidence: {r['Evidence']}
- Assumptions: {r['Assumptions']}
- Use Cases: {r['Use Cases']}
- Limitations: {r['Limitations']}
- Sentiment: {r['Sentiment']}
""")
            prompt = f"""
<system>
You are a comparative analysis expert. Identify:
1. Commonalities
2. Key differences (with table)
3. Conflicts
4. Complementarity
5. Overall evaluation

Output in structured markdown with tables.
</system>

Input Files:
{chr(10).join(summaries)}

Output sections:
1. Core Commonalities
2. Key Differences (table required)
3. Potential Conflicts
4. Complementary Value
5. Overall Assessment
"""
            try:
                raw = await TextAnalyzer.call_ollama(prompt)
                report.append("\n" + raw)
            except Exception as e:
                report.append("\n## ⚠️ Comparison failed\n- Error: " + str(e)[:50])

            times = [float(v['Time'].replace('s','')) for v in valid.values()]
            report.extend([
                "",
                "## ⏱️ Performance",
                f"- Avg time: {sum(times)/len(times):.2f}s",
                f"- Max time: {max(times):.2f}s",
                f"- Min time: {min(times):.2f}s"
            ])
        else:
            report.append("\n## ⚠️ At least 2 valid files required for comparison")

        report.extend([
            "",
            "## 📋 Metadata",
            f"- Total files: {len(results)}",
            f"- Valid files: {n}",
            f"- Failed: {len(results)-n}",
            f"- Time: {time.strftime('%Y-%m-%d %H:%M:%S')}",
            f"- Acceleration: ROCm GPU"
        ])
        return "\n".join(report)

# ====================== File Parser ======================
class FileParser:
    @staticmethod
    def parse_uploaded_file(file_data, filename):
        try:
            content = b""
            if isinstance(file_data, (list, tuple)):
                if len(file_data) > 0:
                    if isinstance(file_data[0], memoryview):
                        content = bytes(file_data[0])
                    elif isinstance(file_data[0], bytes):
                        content = file_data[0]
            elif isinstance(file_data, dict):
                content = file_data.get("content", b"")
                if isinstance(content, memoryview):
                    content = bytes(content)
            elif isinstance(file_data, memoryview):
                content = bytes(file_data)
            elif isinstance(file_data, bytes):
                content = file_data
            else:
                content = str(file_data).encode("utf-8")

            try:
                text = content.decode("utf-8").strip()
            except:
                text = content.decode("gbk", errors="ignore").strip()

            info = {
                "Filename": filename,
                "Size (bytes)": len(content),
                "Characters": len(text),
                "Tokens": Tokenizer.count(text),
                "Preview": text[:200] + "..." if len(text) > 200 else text
            }
            if not text:
                raise ValueError("Empty file")
            return text, info
        except Exception as e:
            raise ValueError(f"Parse failed: {str(e)}")

# ====================== Save Utilities ======================
class SaveTool:
    @staticmethod
    def save_analysis_result(filename, result, info=None, typ="md"):
        try:
            root = "text_analysis_results"
            os.makedirs(root, exist_ok=True)
            safe = re.sub(r'[\\/:*?"<>|]', '_', filename)
            ts = time.strftime("%Y%m%d_%H%M%S")

            if typ == "md":
                path = os.path.join(root, f"{safe}_analysis_{ts}.md")
                md = f"# Deep Analysis Report: {safe}\n\n"
                if info:
                    md += "## File Info\n"
                    for k, v in info.items():
                        md += f"- {k}: {v}\n"
                md += "\n## Results\n"
                if "Error" in result:
                    md += f"- Error: {result['Error']}\n"
                else:
                    keys = ["Summary", "Theme", "Keywords", "Sentiment", "Type",
                            "Thesis", "Evidence", "Assumptions", "Use Cases", "Limitations"]
                    for k in keys:
                        md += f"- **{k}**: {result[k]}\n"
                md += f"\n## Metadata\n- Time: {result.get('Time','0s')}\n"
                with open(path, "w", encoding="utf-8") as f:
                    f.write(md)
                return f"✅ Saved: {path}"

            elif typ == "json":
                path = os.path.join(root, f"{safe}_analysis_{ts}.json")
                out = {"file": info, "results": result, "timestamp": ts}
                with open(path, "w", encoding="utf-8") as f:
                    json.dump(out, f, ensure_ascii=False, indent=2)
                return f"✅ Saved: {path}"
            else:
                return "❌ Unsupported format"
        except Exception as e:
            return f"❌ Save failed: {str(e)}"

    @staticmethod
    async def save_compare_result(results, typ="md"):
        try:
            root = "text_analysis_results"
            os.makedirs(root, exist_ok=True)
            ts = time.strftime("%Y%m%d_%H%M%S")
            report = await TextComparator.compare(results)
            path = os.path.join(root, f"comparison_report_{ts}.md")
            with open(path, "w", encoding="utf-8") as f:
                f.write(report)
            return f"✅ Saved: {path}"
        except Exception as e:
            return f"❌ Save failed: {str(e)}"

# ====================== UI ======================
class TextAnalysisUI:
